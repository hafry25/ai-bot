# ============================================
# Required API Keys
# ============================================
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET=your_binance_secret_here
GEMINI_API_KEY=your_gemini_api_key_here

# live = Binance live, demo = demo-api.binance.com, testnet = testnet.binance.vision
# Buat API key demo di https://demo.binance.com/en/my/settings/api-management
# Untuk demo/testnet wajib pakai API key khusus environment itu, bukan API key live.
EXCHANGE_MODE=live

# ============================================
# Binance Spot Grid Configuration
# ============================================
SYMBOLS=BTC/USDT
INTERVAL_MINUTES=1

# ARITHMETIC = jarak harga tetap, GEOMETRIC = persentase antar level tetap
GRID_MODE=ARITHMETIC
GRID_COUNT=10

# Jika GRID_LOWER_PRICE dan GRID_UPPER_PRICE kosong/0, bot membuat range otomatis
# dari harga pertama kali grid dibuat: current price +/- GRID_RANGE_PCT.
GRID_LOWER_PRICE=0
GRID_UPPER_PRICE=0
GRID_RANGE_PCT=5

# Trailing Range: auto-range ikut naik/turun mengikuti market.
# Saat true, Trailing Up dan Down aktif kecuali dioverride masing-masing.
# Tidak berlaku untuk manual range.
GRID_TRAILING_RANGE_ENABLED=false

# Trailing Up: geser auto-range naik sebesar jumlah grid yang ditembus
# setelah harga mencapai minimal satu interval grid di atas batas atas.
GRID_TRAILING_UP_ENABLED=false
GRID_TRAILING_UP_COOLDOWN_MINUTES=0

# Trailing Down: geser auto-range turun sebesar jumlah grid yang ditembus
# setelah harga mencapai minimal satu interval grid di bawah batas bawah.
GRID_TRAILING_DOWN_ENABLED=false
GRID_TRAILING_DOWN_COOLDOWN_MINUTES=0

# Pilih salah satu:
# - GRID_ORDER_SIZE_USDT untuk nominal per order grid
# - GRID_TOTAL_INVESTMENT_USDT untuk membagi modal ke seluruh grid
GRID_ORDER_SIZE_USDT=20
GRID_TOTAL_INVESTMENT_USDT=0

# Batasi jumlah order aktif agar saldo tidak langsung terkunci semua.
GRID_MAX_ACTIVE_BUY_ORDERS=5
GRID_MAX_ACTIVE_SELL_ORDERS=5

# true = batalkan order grid lama saat bot start lalu buat ulang.
# Gunakan hati-hati di akun live.
GRID_RECREATE_ON_START=false
GRID_CANCEL_OUT_OF_RANGE=true
GRID_REFILL_ON_FILLED=true
GRID_MIN_PROFIT_PCT=0.4
GRID_STATE_FILE=grid-state-spot.json

# Optional exit guard. 0 berarti nonaktif.
GRID_STOP_LOSS_PRICE=0
GRID_TAKE_PROFIT_PRICE=0

# ============================================
# Gemini AI Validation (Optional)
# ============================================
# false = grid berjalan tanpa AI.
# true = Gemini memvalidasi sebelum bot memasang/refill order baru.
AI_VALIDATION_ENABLED=false
GEMINI_MODEL=gemini-2.0-flash-lite
AI_VALIDATION_TIMEFRAME=15m
AI_VALIDATION_LOOKBACK=40
AI_VALIDATION_CACHE_TTL_MS=900000
AI_VALIDATION_MIN_INTERVAL_MS=300000
AI_VALIDATION_BACKOFF_MS=900000
AI_VALIDATION_PRICE_BUCKET_PCT=0.25
AI_VALIDATION_RETRIES=1
AI_MIN_CONFIDENCE=70
AI_STRONG_CONFIDENCE=85

# ============================================
# Kill Switch
# ============================================
KILL_SWITCH_ENABLED=false
STOP_TRADING=false
KILL_SWITCH_FILE=bot-paused.flag

# ============================================
# Fonnte Alerts (Optional)
# ============================================
FONNTE_ENABLED=false
FONNTE_TOKEN=
FONNTE_TARGET=
FONNTE_API_URL=https://api.fonnte.com/send
FONNTE_COUNTRY_CODE=62
FONNTE_TIMEOUT_MS=10000
