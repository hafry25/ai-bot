# Required
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_SECRET=your_binance_secret_here

# live, testnet, or demo
EXCHANGE_MODE=live

# Core bot settings
SYMBOLS=BTC/USDT
INTERVAL_MINUTES=1
GRID_MODE=ARITHMETIC
GRID_COUNT=10

# Use either manual range or auto range
GRID_LOWER_PRICE=0
GRID_UPPER_PRICE=0
GRID_RANGE_PCT=5

# Position sizing
GRID_ORDER_SIZE_USDT=20
GRID_TOTAL_INVESTMENT_USDT=0

# Optional behavior
GRID_MAX_ACTIVE_BUY_ORDERS=5
GRID_MAX_ACTIVE_SELL_ORDERS=5
GRID_RECREATE_ON_START=false
GRID_CANCEL_OUT_OF_RANGE=true
GRID_CANCEL_OUT_OF_RANGE_THRESHOLD_MINUTES=3
GRID_REFILL_ON_FILLED=true
GRID_STATE_FILE=grid-state-spot.json
GRID_POST_ONLY=true
GRID_PRICE_PRECISION_MAX_DEVIATION_PCT=0.05

# Safety
STOP_TRADING=false
KILL_SWITCH_ENABLED=false
KILL_SWITCH_FILE=bot-paused.flag

# Optional AI validation
AI_VALIDATION_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional learning memory
LEARNING_MEMORY_ENABLED=false
LEARNING_MEMORY_PROFIT_THRESHOLD_PCT=0.5

# Optional alerts
FONNTE_ENABLED=false
FONNTE_TOKEN=
FONNTE_TARGET=
